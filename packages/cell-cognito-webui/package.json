{
  "name": "@casfa/cell-cognito-webui",
  "version": "0.1.0",
  "description": "SSO frontend shared UI: Cognito login page, consent page. For SSO cell frontends.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/build-pkg.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "check": "tsc --noEmit && biome check .",
    "prepublishOnly": "bun run build"
  },
  "buildConfig": {
    "bunFlags": [
      "--target=browser",
      "--production"
    ]
  },
  "dependencies": {
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "license": "MIT"
}
