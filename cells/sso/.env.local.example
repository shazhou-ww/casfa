# SSO cell — local overrides. Copy to .env.local (gitignored). Overrides .env for local dev only.
# cell-cli infers DYNAMODB_ENDPOINT from PORT_BASE+2 and DYNAMODB_TABLE_GRANTS from cell name + stage.
# Every variable here must be set to override .env (no optional overrides).

# Port base for local dev (DynamoDB = PORT_BASE+2, API = PORT_BASE+1).
PORT_BASE=7100

# Default for local: leave empty so on localhost SSO uses hostname and all ports (7100, 7120, …) share the cookie.
AUTH_COOKIE_DOMAIN=

# Recommended for local (e.g. debug for more logs).
LOG_LEVEL=debug
