# =============================================================================
# CASFA Monorepo - Shared Environment Variables
# =============================================================================
# Copy to .env and fill in your values. All cells inherit these via cell-cli's
# loadEnvFiles (cell .env takes precedence, then root .env fills gaps).

# =============================================================================
# Cell-based services (sso, server-next, image-workshop, etc.)
# =============================================================================

# AWS SSO Profile (used by all AWS SDK clients: DynamoDB, S3, Cognito, etc.)
AWS_PROFILE=

# Cognito Authentication (shared User Pool)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_gMTKxXOKo
COGNITO_CLIENT_ID=rrr40170csj0160ptr9lusi3k
COGNITO_HOSTED_UI_URL=https://casfa-auth.auth.us-east-1.amazoncognito.com

# Domain (shared zone; per-cell use domain.subdomain + DOMAIN_ROOT in cell .env)
DOMAIN_ZONE=shazhou.me

# ACM certificate for CloudFront custom domain, must be in us-east-1
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:914369185440:certificate/d6f927b4-706d-4613-8614-0d0082998b96

# Google Identity Provider (used by `cell cognito idp setup/sync`)
GOOGLE_CLIENT_ID=1084492958564-ngqgsjbss5ta8676oa101rrg9prcankv.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Microsoft Identity Provider (used by `cell cognito idp setup/sync`)
MICROSOFT_CLIENT_ID=38da332e-7a20-4765-acae-c249e74c6a6a
MICROSOFT_CLIENT_SECRET=

# =============================================================================
# Legacy (apps/server)
# =============================================================================

# S3 Storage
CAS_BUCKET=casfa-cas-914369185440
CAS_PREFIX=dev/cas/v1/
CAS_REGION=us-east-1
