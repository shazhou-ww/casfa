# =============================================================================
# CASFA Monorepo - Shared Environment Variables
# =============================================================================
# Copy to .env and fill in your values. All cells inherit these via cell-cli's
# loadEnvFiles (cell .env takes precedence, then root .env fills gaps).

# AWS SSO Profile (used by all AWS SDK clients: DynamoDB, S3, Cognito, etc.)
AWS_PROFILE=AdministratorAccess-914369185440

# --- Cognito Authentication (shared User Pool) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-app-client-id
COGNITO_HOSTED_UI_URL=https://your-auth-domain.auth.us-east-1.amazoncognito.com

# --- Domain (shared zone, per-cell host overrides in cell .env) ---
DOMAIN_ZONE=example.com

# --- ACM certificate for CloudFront custom domain, must be in us-east-1 ---
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- S3 Storage ---
CAS_BUCKET=casfa-cas-123456789012
CAS_PREFIX=dev/cas/v1/
CAS_REGION=us-east-1

# --- Google Identity Provider (used by `cell cognito idp setup/sync`) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft Identity Provider (used by `cell cognito idp setup/sync`) ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
