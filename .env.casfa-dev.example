# Casfa-Dev Tunnel 本地多服务 env 示例
# 复制为 .env.casfa-dev 或合并到各 app 的 .env。各 app 只需本 app 的 PORT_BASE 及依赖的 base URL。
# Dev 使用两级子域：<subdomain>.<devboxName>.<devRoot>，例如 sso.casfa.mymbp.shazhou.work（与线上一致，需 zone 启用 Total TLS）。
# 将下面的 mymbp 换成你 cell devbox prepare 时填的机器名，shazhou.work 换成你的 devRoot。

# SSO (apps/sso)
PORT_BASE=7100
CELL_BASE_URL=https://sso.casfa.mymbp.shazhou.work
AUTH_COOKIE_DOMAIN=.mymbp.shazhou.work

# server-next / drive (apps/server-next)
PORT_BASE=7120
CELL_BASE_URL=https://drive.casfa.mymbp.shazhou.work
SSO_BASE_URL=https://sso.casfa.mymbp.shazhou.work

# image-workshop (apps/image-workshop)
PORT_BASE=7140
CELL_BASE_URL=https://drive.casfa.mymbp.shazhou.work
SSO_BASE_URL=https://sso.casfa.mymbp.shazhou.work

# agent (apps/agent)
PORT_BASE=7160
SSO_BASE_URL=https://sso.casfa.mymbp.shazhou.work
