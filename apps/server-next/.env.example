# server-next (casfa-next) - Environment
#
# Copy to .env and fill in. For Cognito login, copy COGNITO_* from apps/server/.env
# or use the values below (replace with your real User Pool / Client).

# =============================================================================
# AWS (for deploy - optional, can set in .env up to repo root)
# =============================================================================
# AWS_PROFILE=default

# =============================================================================
# Authentication (Cognito - for dev:cognito and production)
# =============================================================================
# When these are set and MOCK_JWT_SECRET is not set, backend uses Cognito JWT.
# Copy from apps/server/.env if you use the same User Pool.
COGNITO_USER_POOL_ID=us-east-1_gMTKxXOKo
COGNITO_CLIENT_ID=rrr40170csj0160ptr9lusi3k
COGNITO_REGION=us-east-1

# Optional: Cognito Hosted UI base URL (required for "Sign in with OAuth" to redirect to Cognito)
# Example: https://casfa-auth.auth.us-east-1.amazoncognito.com
COGNITO_HOSTED_UI_URL=https://casfa-auth.auth.us-east-1.amazoncognito.com

# Required for OAuth code→token exchange only when not using PKCE.
# With PKCE (frontend sends code_verifier), leave unset — same as old server.
# COGNITO_CLIENT_SECRET=

# =============================================================================
# Mock auth (for bun run dev only - do not set for Cognito verification)
# =============================================================================
# When set, backend uses mock JWT; /api/dev/mock-token is available.
# Leave unset or empty when using dev:cognito.
# MOCK_JWT_SECRET=dev-mock-secret

# =============================================================================
# Storage / DB (local dev: Docker DynamoDB + serverless-s3-local)
# =============================================================================
# DB = DynamoDB only; Blob = S3 only. For local, dev scripts start Docker
# DynamoDB (dev: 7102 persistent, local-test: 7112 in-memory) and S3 (4569).
# DYNAMODB_ENDPOINT is set by dev/dev:cognito/dev:test scripts; override if needed:
# DYNAMODB_ENDPOINT=http://localhost:7102
# S3_ENDPOINT=http://localhost:4569
# S3_BUCKET=casfa-next-dev-blob
