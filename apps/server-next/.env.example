# server-next (casfa-next) - Environment
#
# Copy to .env and fill in. Variables are used as Cell params (see cell.yaml params).
# Tables: realms, grants (managed by Cell).

# =============================================================================
# Port (optional - Cell uses for port allocation)
# =============================================================================
# PORT_BASE=7100

# =============================================================================
# Cognito
# =============================================================================
# When using SSO (SSO_BASE_URL set): only REGION + USER_POOL_ID are required (JWT
# verification). CLIENT_ID, HOSTED_UI_URL, CLIENT_SECRET are used by the SSO cell, not here.
# When not using SSO (legacy self-hosted OAuth): set all of REGION, USER_POOL_ID,
# CLIENT_ID, HOSTED_UI_URL; CLIENT_SECRET only if not using PKCE.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_gMTKxXOKo
# Only needed when SSO_BASE_URL is not set (legacy OAuth on this cell):
# COGNITO_CLIENT_ID=rrr40170csj0160ptr9lusi3k
# COGNITO_HOSTED_UI_URL=https://casfa-auth.auth.us-east-1.amazoncognito.com
# COGNITO_CLIENT_SECRET=  # optional; PKCE can leave unset

# =============================================================================
# Mock auth (test only - do not set for dev or production)
# =============================================================================
# Only used when NODE_ENV=test (e.g. e2e). For dev use Cognito above; leave unset.
# MOCK_JWT_SECRET=dev-mock-secret

# =============================================================================
# Optional
# =============================================================================
# MAX_BRANCH_TTL_MS=86400000
# LOG_LEVEL=info

# =============================================================================
# SSO cookie (optional - same parent domain). If set, access token is set in HttpOnly cookie.
# =============================================================================
# AUTH_COOKIE_NAME=casfa_token
# AUTH_COOKIE_DOMAIN=.yourdomain.com
# AUTH_COOKIE_PATH=/
# AUTH_COOKIE_MAX_AGE_SECONDS=86400
