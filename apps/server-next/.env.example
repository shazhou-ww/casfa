# server-next (casfa-next) — copy to .env and set values.
# Every !Env in cell.yaml must be set here (or inherited from root .env).
# CELL_* are injected by cell-cli; do not set.

# --- Cognito (shared, typically inherited from root .env) ---
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# --- Domain ---
# DOMAIN_ZONE inherited from root .env
DOMAIN_HOST=beta.casfa.example.com

# --- SSO ---
SSO_BASE_URL=https://sso.casfa.example.com

# --- Logging ---
LOG_LEVEL=info
