# server-next (casfa-next) - Environment
#
# Copy to .env and fill in. Variables are used as Cell params (see cell.yaml params).
# Tables: realms, grants (managed by Cell).

# =============================================================================
# Port (optional - Cell uses for port allocation)
# =============================================================================
# PORT_BASE=7100

# =============================================================================
# Cognito (required for production; optional for local mock auth)
# =============================================================================
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_gMTKxXOKo
COGNITO_CLIENT_ID=rrr40170csj0160ptr9lusi3k
COGNITO_HOSTED_UI_URL=https://casfa-auth.auth.us-east-1.amazoncognito.com
# Required for OAuth code→token only when not using PKCE. With PKCE, leave unset.
# COGNITO_CLIENT_SECRET=

# =============================================================================
# Mock auth (test only - do not set for dev or production)
# =============================================================================
# Only used when NODE_ENV=test (e.g. e2e). For dev use Cognito above; leave unset.
# MOCK_JWT_SECRET=dev-mock-secret

# =============================================================================
# OAuth / API URLs (cell dev sets these automatically)
# =============================================================================
# API_BASE_URL = backend URL (Cognito redirect_uri). Production: https://beta.casfa.shazhou.me
# APP_ORIGIN = frontend origin (where to redirect after OAuth callback). Production: https://beta.casfa.shazhou.me
# API_BASE_URL=https://beta.casfa.shazhou.me
# APP_ORIGIN=https://beta.casfa.shazhou.me

# =============================================================================
# Optional
# =============================================================================
# MAX_BRANCH_TTL_MS=86400000
# LOG_LEVEL=info
