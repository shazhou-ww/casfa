# server-next — local overrides. Copy to .env.local (gitignored). Overrides .env for local dev only.
# cell-cli infers DYNAMODB_ENDPOINT from PORT_BASE+2, S3_ENDPOINT from PORT_BASE+4.
# Every variable here must be set to override .env (no optional overrides).

# Port base for local dev (API = PORT_BASE+1, DynamoDB = PORT_BASE+2, frontend = PORT_BASE+0, S3 = PORT_BASE+4).
PORT_BASE=7100

# SSO cell URL when running locally (e.g. cell dev in apps/sso uses port 7000; adjust if different).
SSO_BASE_URL=http://localhost:7000

# Recommended for local (e.g. debug for more logs).
LOG_LEVEL=debug
