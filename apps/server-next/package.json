{
  "name": "@casfa/server-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "aws:login": "bun ../cell-cli/src/cli.ts aws login",
    "aws:logout": "bun ../cell-cli/src/cli.ts aws logout",
    "clean": "rimraf .esbuild .local-storage",
    "clean:db": "rimraf .dynamodb",
    "dev": "bun ../cell-cli/src/cli.ts dev",
    "dev:bun": "bun run backend/index.ts",
    "deploy": "bun ../cell-cli/src/cli.ts deploy",
    "typecheck": "tsc --noEmit",
    "test": "bun ../cell-cli/src/cli.ts test",
    "test:unit": "bun test backend/",
    "test:e2e": "bun ../cell-cli/src/cli.ts test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@casfa/cas": "workspace:*",
    "@casfa/cell-auth-client": "workspace:*",
    "@casfa/cell-cognito": "workspace:*",
    "@casfa/cell-oauth": "workspace:*",
    "@casfa/core": "workspace:*",
    "@casfa/storage-fs": "workspace:*",
    "@casfa/storage-memory": "workspace:*",
    "@casfa/storage-s3": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "@noble/hashes": "^1.7.2",
    "hono": "^4.6.0",
    "jose": "^6.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@casfa/cell-cli": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
