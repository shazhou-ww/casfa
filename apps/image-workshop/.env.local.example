# image-workshop — local overrides. Copy to .env.local (gitignored). Overrides .env for local dev only.
# cell-cli infers DYNAMODB_ENDPOINT from PORT_BASE+2.
# Every variable here must be set to override .env (no optional overrides).

# Port base for local dev (API = PORT_BASE+1, DynamoDB = PORT_BASE+2, frontend = PORT_BASE+0).
PORT_BASE=7140

# 仅当「全部走 localhost、不经过 tunnel」时必填（SSO 用 PORT_BASE=7100）。
# 用 tunnel 时可不设，后端会按 CELL_BASE_URL 推导（如 drive.casfa.xxx → sso.casfa.xxx）。
SSO_BASE_URL=http://localhost:7100

# Recommended for local (e.g. debug for more logs).
LOG_LEVEL=debug

# Leave empty: on localhost SSO defaults to hostname so all ports share the cookie.
AUTH_COOKIE_DOMAIN=
