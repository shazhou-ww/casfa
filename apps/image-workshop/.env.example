# image-workshop — copy to .env and set values.
# Every !Env/!Secret in cell.yaml must be set here. CELL_* are injected by cell-cli; do not set.
# For local overrides, copy .env.local.example to .env.local.

# =============================================================================
# Required (!Env / !Secret in cell.yaml)
# =============================================================================
LOG_LEVEL=info
SSO_BASE_URL=https://auth.casfa.shazhou.me

# BFL (Black Forest Labs) API key for FLUX image generation. Get from https://dashboard.bfl.ai/
BFL_API_KEY=
