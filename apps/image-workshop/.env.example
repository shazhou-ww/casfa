# image-workshop environment variables (copy to .env and fill in values)

# BFL (Black Forest Labs) API key for FLUX image generation
# Get from https://dashboard.bfl.ai/
BFL_API_KEY=

# Google Identity Provider (for Cognito social sign-in)
GOOGLE_CLIENT_SECRET=

# Microsoft Identity Provider (for Cognito social sign-in)
MICROSOFT_CLIENT_SECRET=

# Base port for local dev servers (backend = BASE+1, DynamoDB = BASE+2, frontend = BASE+0)
PORT_BASE=7200

# Shared secret for E2E test JWT verification (backend uses HS256 instead of Cognito JWKS)
# Only uncomment when running E2E tests; normal dev uses real Cognito JWKS verification
# E2E_MOCK_JWT_SECRET=e2e-test-secret
