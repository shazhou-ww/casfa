# image-workshop — copy to .env and set values.
# Default instance: config in cell.yaml. Symbiont: cell.symbiont.yaml; set CLOUDFLARE_API_TOKEN when deploying -i symbiont.
# CELL_* are injected by cell-cli; do not set.

# BFL (Black Forest Labs) API key for FLUX image generation. Get from https://dashboard.bfl.ai/
BFL_API_KEY=
