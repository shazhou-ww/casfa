# Optional AWS settings for deploy
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Shared stack params injected via otavia (single source of truth)
# Resolved from mount at runtime, but still referenced by stack params.
# Stage-specific overrides:
# - .env.dev    (otavia dev)
# - .env.test   (otavia test)
# - .env.deploy (otavia deploy)
# Port strategy:
# - put only PORT_BASE in .env.dev/.env.test
# - all local ports are derived from PORT_BASE + stage offsets
# Keep this aligned with your main host/mount (example: https://casfa.shazhou.me/sso)
SSO_BASE_URL=

# Secret params
BFL_API_KEY=
