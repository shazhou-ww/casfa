# SSO cell — copy to .env and set values. No secrets in this file.
# Every !Env in cell.yaml must be set here. CELL_* are injected by cell-cli; do not set.
# For local overrides, copy .env.local.example to .env.local.

# Parent domain for cookie sharing (deployed: e.g. .casfa.example.com; leave empty for same-origin).
AUTH_COOKIE_DOMAIN=.casfa.shazhou.me

# Log level (may differ between local and production).
LOG_LEVEL=info
