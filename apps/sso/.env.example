# SSO cell — copy to .env and set values. No secrets in this file.
# Two instances:
#   - Default: cell.yaml has DOMAIN_* / AUTH_COOKIE_DOMAIN / COGNITO in params (edit cell.yaml to match your env).
#   - Symbiont: cell.symbiont.yaml overrides. Deploy: cell deploy -i symbiont
#     (set CLOUDFLARE_API_TOKEN in .env when deploying symbiont)
# CELL_* are injected by cell-cli; do not set.

# --- Cookie (required: cell.yaml uses !Env AUTH_COOKIE_DOMAIN) ---
# Parent domain for auth cookie (e.g. .casfa.shazhou.me). Local dev: set in .env.local to empty or localhost.
AUTH_COOKIE_DOMAIN=.casfa.shazhou.me

# --- Cloudflare (for instances using dns: cloudflare; e.g. symbiont) ---
# CLOUDFLARE_API_TOKEN=your-token

# --- Logging ---
LOG_LEVEL=info
