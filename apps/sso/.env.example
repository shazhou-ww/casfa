# SSO cell — copy to .env and set values. No secrets in this file.
# Every !Env in cell.yaml must be set here (or inherited from root .env).
# CELL_* are injected by cell-cli; do not set.

# --- Cognito (shared, typically inherited from root .env) ---
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_CLIENT_ID=your-sso-client-id
# COGNITO_HOSTED_UI_URL=https://your-auth-domain.auth.us-east-1.amazoncognito.com

# --- Domain ---
# DOMAIN_ZONE inherited from root .env
DOMAIN_HOST=sso.casfa.example.com

# --- Cookie config ---
AUTH_COOKIE_DOMAIN=.casfa.example.com

# --- Logging ---
LOG_LEVEL=info
