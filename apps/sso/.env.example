# SSO cell — copy to .env and set values. No secrets in this file.

# Required: public base URL of this SSO cell (e.g. https://auth.casfa.example.com)
CELL_BASE_URL=

# Cognito (same as other cells using this SSO)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_HOSTED_UI_URL=

# Cookie names (defaults: auth, auth_refresh)
AUTH_COOKIE_NAME=auth
AUTH_REFRESH_COOKIE_NAME=auth_refresh

# Parent domain for cookie sharing (e.g. .casfa.example.com). Omit for same-origin only.
AUTH_COOKIE_DOMAIN=

# Optional: path and max-age (defaults: /, /oauth/refresh; max-age from token TTL)
# AUTH_COOKIE_PATH=/
# AUTH_COOKIE_MAX_AGE_SECONDS=3600
# AUTH_REFRESH_COOKIE_PATH=/oauth/refresh
# AUTH_REFRESH_COOKIE_MAX_AGE_SECONDS=2592000

# Local dev: DynamoDB endpoint (e.g. http://localhost:7102). Omit in AWS.
# DYNAMODB_ENDPOINT=
# DYNAMODB_TABLE_GRANTS=sso-dev-grants

# Optional
# LOG_LEVEL=info
