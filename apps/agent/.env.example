# Agent cell — copy to .env or .env.local. No secrets in this file.
# CELL_* and table names are injected by cell dev / deploy; override only for local DynamoDB.
# For local dev: set SSO_BASE_URL and COGNITO_* to match your SSO, or use MOCK_JWT_SECRET for tests.

LOG_LEVEL=info

# Optional: local DynamoDB (e.g. http://localhost:8000)
# DYNAMODB_ENDPOINT=http://localhost:8000

# Optional: mock JWT for e2e (CELL_STAGE=test)
# MOCK_JWT_SECRET=test-secret
